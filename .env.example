APP_NAME=SmartLMS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://smartlms.io.vn
APP_TIMEZONE=Asia/Ho_Chi_Minh
FORCE_HTTPS=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=lms_db
DB_USERNAME=lms_user
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

DB_VECTOR_HOST=postgres_vector
DB_VECTOR_PORT=5432
DB_VECTOR_DATABASE=lms_ai
DB_VECTOR_USERNAME=ai_user
DB_VECTOR_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_INTERNAL_HOST=lms-reverb
REVERB_INTERNAL_PORT=8080
REVERB_INTERNAL_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=ws.smartlms.io.vn
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=700

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_INPUT_COST_PER_MILLION=0.14
DEEPSEEK_OUTPUT_COST_PER_MILLION=0.28
GOOGLE_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
AI_CHAT_RATE_LIMIT=20
AI_GENERATION_RATE_LIMIT=8
AI_RAG_RESULT_LIMIT=5
AI_RAG_CONTEXT_LIMIT=9000
AI_RAG_MAX_DISTANCE=0.65
AI_RAG_DISTANCE_MARGIN=0.18
AI_EMBEDDING_DIMENSIONS=3072
AI_EMBEDDING_CHUNK_SIZE=1200
AI_EMBEDDING_CHUNK_OVERLAP=200
AI_OCR_ENABLED=true
AI_OCR_LANGUAGES=vie+eng
AI_OCR_MAX_PAGES=50
AI_OCR_TIMEOUT_PER_PAGE=60
AI_OCR_MINIMUM_TEXT_CHARACTERS=80

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SUBMISSION_FILESYSTEM_DISK=public
LESSON_ATTACHMENT_FILESYSTEM_DISK=public
SHARED_DOCUMENT_FILESYSTEM_DISK=r2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_REGION=auto
R2_URL=
R2_USE_PATH_STYLE_ENDPOINT=false

BACKUP_TIMEZONE=Asia/Ho_Chi_Minh
BACKUP_KEEP_LOCAL_COPIES=10
BACKUP_UPLOAD_DISK=
BACKUP_REMOTE_DIRECTORY=backups
BACKUP_SCHEDULE_ENABLED=false
BACKUP_SCHEDULE_TIME=02:00
BACKUP_SCHEDULE_UPLOAD_R2=false

VITE_APP_NAME="${APP_NAME}"
